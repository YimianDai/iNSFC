\newenvironment{MS}%
{%
  \begingroup
  \MSzh\ensong
  % 维持你的原始设置，不做 \setstretch{1.0}
  \fontsize{12.5pt}{23pt}\selectfont
  \setlength{\baselineskip}{23pt}
  
  % 地修正“上行距大”的问题
  % 因为正文行高（23pt*1.6）太离谱了，必须用更狠的负值把公式拉上来
  \setlength{\abovedisplayskip}{-13pt} 
  \setlength{\belowdisplayskip}{9pt}
  \setlength{\abovedisplayshortskip}{-10pt}
  \setlength{\belowdisplayshortskip}{15pt}
  \setlength{\jot}{2pt} 

  % --- 只在公式环境内部“降压” ---
  \AtBeginEnvironment{equation}{\def\baselinestretch{1.1}\selectfont}
  \AtBeginEnvironment{align}{\def\baselinestretch{1.1}\selectfont}
  \AtBeginEnvironment{cases}{\def\baselinestretch{1.1}\selectfont}

  \inMStrue
}%
{%
  \inMSfalse
  \endgroup
}


