% For the chapter name like （一）立项依据与研究内容（4000-8000字）
\let\origchapter\chapter
\renewcommand\chapter{\@ifstar{\starchapter}{\nostarchapter}}

\newcommand\nostarchapter[2][0pt]{%
\refstepcounter{chapter}%
\begingroup
    \global\afterfirstsectionfalse
    \global\afterfirstsubsectionfalse

    % --- 前间距：从第二个 chapter 开始 ---
    \ifafterfirstchapter
        \vspace{\ChapterPreSkip}
    \else
        \global\afterfirstchaptertrue
    \fi

    \color{NSFblue}
    \zhkai\enkai\fontsize{14.2pt}{22pt}\selectfont
    \setlength{\baselineskip}{22pt}

    \par\noindent
    \textbf{%
        \hspace{27pt}%
        \ifdim#1>0pt\relax\hspace*{#1}\fi
        （\chinese{chapter}）
    }#2\par

    \vspace{\ChapterPostSkip}
\endgroup}



